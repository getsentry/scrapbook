{
  "name": "@sentry/scrapbook",
  "version": "0.1.0",
  "description": "Visual snapshot testing framework for React components using Playwright",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./emotion": {
      "types": "./dist/renderers/emotion.d.ts",
      "import": "./dist/renderers/emotion.mjs",
      "require": "./dist/renderers/emotion.js"
    },
    "./jest-preset": "./jest-preset.js"
  },
  "files": [
    "dist",
    "jest-preset.js"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "playwright": ">=1.40"
  },
  "peerDependenciesMeta": {
    "@emotion/cache": { "optional": true },
    "@emotion/react": { "optional": true },
    "@emotion/server": { "optional": true }
  },
  "devDependencies": {
    "@emotion/cache": "^11.11.0",
    "@emotion/react": "^11.11.0",
    "@emotion/server": "^11.11.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/getsentry/scrapbook.git"
  }
}
