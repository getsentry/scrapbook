{
  "name": "@sentry/scrapbook-jest",
  "version": "0.0.1",
  "description": "Jest integration for @sentry/scrapbook",
  "exports": {
    "./setup": {
      "types": "./dist/setup.d.ts",
      "import": "./dist/setup.mjs",
      "require": "./dist/setup.js"
    },
    "./framework": {
      "types": "./dist/framework.d.ts",
      "import": "./dist/framework.mjs",
      "require": "./dist/framework.js"
    },
    "./preset": "./jest-preset.js",
    "./jest-preset": "./jest-preset.js",
    "./jest-preset.js": "./jest-preset.js"
  },
  "files": [
    "dist",
    "jest-preset.js"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@sentry/scrapbook": "*",
    "jest": ">=27",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@sentry/scrapbook": "workspace:*",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/getsentry/scrapbook.git"
  }
}
