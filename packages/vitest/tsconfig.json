{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "react",
    "types": ["node"],
    "paths": {
      "@sentry/scrapbook": ["../core/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
